{
  "cli": {
    "version": ">= 0.47.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    },
    "playstore": {
      "android": {
        "track": "production",
        "releaseStatus": "completed"
      }
    },
    "testflight": {
      "ios": {
        "ascAppId": "1603506959"
      }
    },
    "appstore": {
      "ios": {
        "ascAppId": "1603506959"
      }
    }
  }
}
